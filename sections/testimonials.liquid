<section class="section section--alt">
  <div class="container">
    <div class="section-header fade-up">
      <p class="section-eyebrow">{{ section.settings.eyebrow }}</p>
      <h2>{{ section.settings.heading }}</h2>
    </div>
    <div class="testimonials-grid">
      {%- for block in section.blocks -%}
        <div class="testimonial-card fade-up" {{ block.shopify_attributes }}>
          <div class="stars">★★★★★</div>
          <blockquote>{{ block.settings.quote }}</blockquote>
          <cite>{{ block.settings.author }}<span>{{ block.settings.location }}</span></cite>
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>
{% schema %}{"name":"Testimonials","tag":"section","max_blocks":6,"settings":[{"type":"text","id":"eyebrow","label":"Eyebrow","default":"What Our Customers Say"},{"type":"text","id":"heading","label":"Heading","default":"Loved by Thousands"}],"blocks":[{"type":"testimonial","name":"Testimonial","settings":[{"type":"textarea","id":"quote","label":"Quote","default":"Absolutely beautiful products."},{"type":"text","id":"author","label":"Author","default":"Priya S."},{"type":"text","id":"location","label":"Location","default":"Chennai"}]}],"presets":[{"name":"Testimonials"}]}{% endschema %}
