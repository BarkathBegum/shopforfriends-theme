<footer class="site-footer" role="contentinfo">
  <div class="container">
    <div class="footer-grid">
      <div class="footer-brand">
        <a href="{{ routes.root_url }}" class="header-logo">
          {%- if section.settings.logo != blank -%}
            <img src="{{ section.settings.logo | image_url: height: 40 }}" alt="{{ shop.name }}" height="40">
          {%- else -%}
            {{ shop.name }}
          {%- endif -%}
        </a>
        <p>{{ section.settings.tagline }}</p>
        <div class="footer-social">
          {%- if section.settings.instagram != blank -%}<a href="{{ section.settings.instagram }}" class="social-link" aria-label="Instagram" target="_blank" rel="noopener">IG</a>{%- endif -%}
          {%- if section.settings.facebook != blank -%}<a href="{{ section.settings.facebook }}" class="social-link" aria-label="Facebook" target="_blank" rel="noopener">FB</a>{%- endif -%}
        </div>
      </div>
      <div class="footer-col"><h4>Shop</h4><nav class="footer-links">{%- for link in linklists[section.settings.shop_menu].links -%}<a href="{{ link.url }}">{{ link.title }}</a>{%- endfor -%}</nav></div>
      <div class="footer-col"><h4>Help</h4><nav class="footer-links">{%- for link in linklists[section.settings.help_menu].links -%}<a href="{{ link.url }}">{{ link.title }}</a>{%- endfor -%}</nav></div>
      <div class="footer-col"><h4>Contact</h4><div class="footer-links">{%- if section.settings.email != blank -%}<a href="mailto:{{ section.settings.email }}">{{ section.settings.email }}</a>{%- endif -%}</div></div>
    </div>
    <div class="footer-bottom">
      <p>&copy; {{ 'now' | date: '%Y' }} {{ shop.name }}. All rights reserved.</p>
    </div>
  </div>
</footer>
{% schema %}{"name":"Footer","settings":[{"type":"image_picker","id":"logo","label":"Footer logo"},{"type":"textarea","id":"tagline","label":"Tagline","default":"Luxury gifts and lifestyle pieces curated with love."},{"type":"url","id":"instagram","label":"Instagram URL"},{"type":"url","id":"facebook","label":"Facebook URL"},{"type":"link_list","id":"shop_menu","label":"Shop menu","default":"main-menu"},{"type":"link_list","id":"help_menu","label":"Help menu","default":"footer"},{"type":"text","id":"email","label":"Contact email","default":"barkathbegum@gmail.com"},{"type":"text","id":"phone","label":"Phone number"}]}{% endschema %}
