<section class="section section--dark" id="featured-collection">
  <div class="container">
    <div class="section-header fade-up">
      <p class="section-eyebrow">{{ section.settings.eyebrow }}</p>
      <h2>{{ section.settings.heading }}</h2>
      <div class="gold-divider"><span class="gold-divider-icon">✦ ✦ ✦</span></div>
      <p>{{ section.settings.subheading }}</p>
    </div>

    {%- assign collection = collections[section.settings.collection] -%}
    <div class="product-grid">
      {%- for product in collection.products limit: section.settings.products_limit -%}
        <article class="product-card fade-up" style="transition-delay: {{ forloop.index0 | times: 80 }}ms;">
          <a href="{{ product.url }}" class="product-image-wrap" aria-label="{{ product.title }}">
            {%- if product.featured_image -%}
              <img src="{{ product.featured_image | image_url: width: 600 }}"
                   alt="{{ product.featured_image.alt | default: product.title | escape }}"
                   width="600" loading="lazy">
            {%- else -%}
              <div style="width:100%;height:100%;background:var(--color-surface);display:flex;align-items:center;justify-content:center;color:var(--color-text-faint);">No Image</div>
            {%- endif -%}

            {%- if product.compare_at_price > product.price -%}
              <span class="product-badge">Sale</span>
            {%- elsif product.tags contains 'new' -%}
              <span class="product-badge">New</span>
            {%- endif -%}

            <div class="product-actions">
              <button class="product-action-btn add-to-cart-btn" aria-label="Quick add to cart"
                data-product-id="{{ product.variants.first.id }}">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>
              </button>
              <a href="{{ product.url }}" class="product-action-btn" aria-label="Quick view">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
              </a>
            </div>
          </a>

          <div class="product-info">
            <p class="product-category">{{ product.type | default: 'Home & Living' }}</p>
            <div class="product-stars" aria-label="5 stars">★★★★★</div>
            <h3 class="product-title">
              <a href="{{ product.url }}">{{ product.title }}</a>
            </h3>
            <div class="product-price">
              <span class="price-current">{{ product.price | money }}</span>
              {%- if product.compare_at_price > product.price -%}
                <span class="price-original">{{ product.compare_at_price | money }}</span>
              {%- endif -%}
            </div>
          </div>
        </article>
      {%- else -%}
        <p style="color:var(--color-text-muted);">No products found in this collection.</p>
      {%- endfor -%}
    </div>

    {%- if section.settings.show_view_all -%}
      <div style="text-align:center; margin-top:56px;" class="fade-up">
        <a href="{{ collection.url }}" class="btn btn--outline">View All Collection</a>
      </div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Featured Collection",
  "tag": "section",
  "settings": [
    { "type": "text",        "id": "eyebrow",        "label": "Eyebrow",         "default": "Curated for You" },
    { "type": "text",        "id": "heading",        "label": "Heading",         "default": "Our Collections" },
    { "type": "textarea",    "id": "subheading",     "label": "Subheading",      "default": "Timeless pieces designed to transform your living space." },
    { "type": "collection",  "id": "collection",     "label": "Collection" },
    { "type": "range",       "id": "products_limit", "label": "Products to show","min": 2, "max": 12, "step": 1, "default": 4 },
    { "type": "checkbox",    "id": "show_view_all",  "label": "Show 'View All'",  "default": true }
  ],
  "presets": [{ "name": "Featured Collection" }]
}
{% endschema %}
