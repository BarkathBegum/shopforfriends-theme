<section class="section section--dark" id="featured-collection">
  <div class="container">
    <div class="section-header fade-up">
      <p class="section-eyebrow">{{ section.settings.eyebrow }}</p>
      <h2>{{ section.settings.heading }}</h2>
      <p>{{ section.settings.subheading }}</p>
    </div>
    {%- assign collection = collections[section.settings.collection] -%}
    <div class="product-grid">
      {%- for product in collection.products limit: section.settings.products_limit -%}
        <article class="product-card fade-up">
          <a href="{{ product.url }}" class="product-image-wrap">
            {%- if product.featured_image -%}
              <img src="{{ product.featured_image | image_url: width: 600 }}" alt="{{ product.featured_image.alt | default: product.title | escape }}" width="600" loading="lazy">
            {%- endif -%}
          </a>
          <div class="product-info">
            <h3 class="product-title"><a href="{{ product.url }}">{{ product.title }}</a></h3>
            <div class="product-price">
              <span class="price-current">{{ product.price | money }}</span>
              {%- if product.compare_at_price > product.price -%}<span class="price-original">{{ product.compare_at_price | money }}</span>{%- endif -%}
            </div>
          </div>
        </article>
      {%- else -%}<p>No products found.</p>{%- endfor -%}
    </div>
    {%- if section.settings.show_view_all -%}
      <div style="text-align:center;margin-top:56px;"><a href="{{ collection.url }}" class="btn btn--outline">View All</a></div>
    {%- endif -%}
  </div>
</section>
{% schema %}{"name":"Featured Collection","tag":"section","settings":[{"type":"text","id":"eyebrow","label":"Eyebrow","default":"Curated for You"},{"type":"text","id":"heading","label":"Heading","default":"Our Collections"},{"type":"textarea","id":"subheading","label":"Subheading","default":"Timeless pieces for your home and lifestyle."},{"type":"collection","id":"collection","label":"Collection"},{"type":"range","id":"products_limit","label":"Products","min":2,"max":12,"step":1,"default":4},{"type":"checkbox","id":"show_view_all","label":"Show View All","default":true}],"presets":[{"name":"Featured Collection"}]}{% endschema %}
