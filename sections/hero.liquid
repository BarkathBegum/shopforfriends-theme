<section class="hero">
  <!-- Background Image -->
  <div class="hero-bg"
    style="background-image: url('{{ section.settings.hero_image | image_url: width: 2000 }}');"
    aria-hidden="true">
  </div>

  <div class="container">
    <div class="hero-content">
      <p class="hero-eyebrow">{{ section.settings.eyebrow }}</p>
      <h1>{{ section.settings.heading }}</h1>
      <p class="hero-subtitle">{{ section.settings.subheading }}</p>
      <div class="hero-cta">
        {%- if section.settings.btn1_label != blank -%}
          <a href="{{ section.settings.btn1_url }}" class="btn btn--gold">{{ section.settings.btn1_label }}</a>
        {%- endif -%}
        {%- if section.settings.btn2_label != blank -%}
          <a href="{{ section.settings.btn2_url }}" class="btn btn--outline">{{ section.settings.btn2_label }}</a>
        {%- endif -%}
      </div>
    </div>
  </div>

  <!-- Scroll hint -->
  <div class="hero-scroll" aria-hidden="true">
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 5v14M5 12l7 7 7-7"/></svg>
    <span>Scroll</span>
  </div>
</section>

{% schema %}
{
  "name": "Hero Banner",
  "tag": "section",
  "settings": [
    { "type": "image_picker", "id": "hero_image",  "label": "Background image" },
    { "type": "text",         "id": "eyebrow",     "label": "Eyebrow text",  "default": "New Collection 2025" },
    { "type": "richtext",     "id": "heading",     "label": "Heading",       "default": "<p>Elevate Your Living Space</p>" },
    { "type": "textarea",     "id": "subheading",  "label": "Subheading",    "default": "Curated luxury pieces for the discerning home." },
    { "type": "text",         "id": "btn1_label",  "label": "Button 1 label","default": "Shop Collection" },
    { "type": "url",          "id": "btn1_url",    "label": "Button 1 link" },
    { "type": "text",         "id": "btn2_label",  "label": "Button 2 label","default": "Our Story" },
    { "type": "url",          "id": "btn2_url",    "label": "Button 2 link" }
  ],
  "presets": [{ "name": "Hero Banner" }]
}
{% endschema %}
