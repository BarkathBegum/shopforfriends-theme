<section class="section section--dark">
  <div class="container">
    <div class="newsletter-wrap fade-up">
      <p class="section-eyebrow">{{ section.settings.eyebrow }}</p>
      <h2>{{ section.settings.heading }}</h2>
      <p>{{ section.settings.subheading }}</p>
      {% form 'customer', id: 'newsletter-form', class: 'newsletter-form' %}
        <input type="hidden" name="contact[tags]" value="newsletter">
        <input class="newsletter-input"
               type="email"
               name="contact[email]"
               placeholder="{{ section.settings.placeholder }}"
               required
               autocomplete="email">
        <button type="submit" class="btn btn--gold">{{ section.settings.btn_label }}</button>
      {% endform %}
      {%- if section.settings.disclaimer != blank -%}
        <p style="margin-top:16px;font-size:0.75rem;color:var(--color-text-faint);">{{ section.settings.disclaimer }}</p>
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Newsletter",
  "tag": "section",
  "settings": [
    { "type": "text",     "id": "eyebrow",     "label": "Eyebrow",      "default": "Join the Inner Circle" },
    { "type": "text",     "id": "heading",     "label": "Heading",      "default": "Exclusive Access & Offers" },
    { "type": "textarea", "id": "subheading",  "label": "Subheading",   "default": "Be the first to discover new collections, member-only discounts, and styling inspiration delivered straight to your inbox." },
    { "type": "text",     "id": "placeholder", "label": "Input placeholder", "default": "Your email address" },
    { "type": "text",     "id": "btn_label",   "label": "Button label", "default": "Subscribe" },
    { "type": "text",     "id": "disclaimer",  "label": "Disclaimer text", "default": "No spam, ever. Unsubscribe anytime." }
  ],
  "presets": [{ "name": "Newsletter" }]
}
{% endschema %}
