{%- assign product = product -%}
<section class="product-detail">
  <div class="container">
    <nav class="breadcrumb">
      <a href="/">Home</a> &rsaquo;
      <a href="/collections/all">All Products</a> &rsaquo;
      <span style="color:var(--color-gold);">{{ product.title }}</span>
    </nav>
    <div class="product-detail-grid">
      <div class="product-gallery">
        <div class="product-main-image">
          <img id="main-product-img"
            src="{{ product.featured_image | image_url: width: 900 }}"
            alt="{{ product.featured_image.alt | default: product.title | escape }}"
            width="900" style="width:100%;height:auto;">
        </div>
        {%- if product.images.size > 1 -%}
        <div class="product-thumbs">
          {%- for image in product.images -%}
            <button class="thumb-btn{% if forloop.first %} active{% endif %}"
              onclick="document.getElementById('main-product-img').src='{{ image | image_url: width: 900 }}';this.closest('.product-thumbs').querySelectorAll('.thumb-btn').forEach(b=>b.classList.remove('active'));this.classList.add('active');">
              <img src="{{ image | image_url: width: 160 }}" alt="{{ image.alt | escape }}" width="80" height="80">
            </button>
          {%- endfor -%}
        </div>
        {%- endif -%}
      </div>
      <div class="product-detail-info">
        {%- if product.type != blank -%}<p class="product-category">{{ product.type }}</p>{%- endif -%}
        <h1 class="product-detail-title">{{ product.title }}</h1>

        <!-- Price — no translation filter, plain conditional -->
        <div class="product-detail-price">
          {%- if product.compare_at_price > product.price -%}
            <span class="price-current">{{ product.price | money }}</span>
            <span class="price-original">{{ product.compare_at_price | money }}</span>
            <span class="price-save">Save {{ product.compare_at_price | minus: product.price | money }}</span>
          {%- else -%}
            <span class="price-current">{{ product.price | money }}</span>
          {%- endif -%}
        </div>

        {%- unless product.available -%}
          <p style="color:#c0392b;font-size:0.85rem;margin-bottom:12px;">Currently out of stock</p>
        {%- endunless -%}

        {%- form 'product', product, id: 'product-form' -%}
          {%- if product.variants.size > 1 -%}
            <div style="margin-bottom:20px;">
              <label style="font-size:0.75rem;letter-spacing:0.1em;text-transform:uppercase;color:var(--color-text-muted);display:block;margin-bottom:8px;">{{ product.options.first }}</label>
              <select name="id" style="width:100%;padding:12px 16px;background:var(--color-surface);border:1px solid var(--color-border);color:var(--color-text);font-family:inherit;font-size:0.9rem;outline:none;">
                {%- for variant in product.variants -%}
                  <option value="{{ variant.id }}" {% unless variant.available %}disabled{% endunless %}>
                    {{ variant.title }} — {{ variant.price | money }}
                  </option>
                {%- endfor -%}
              </select>
            </div>
          {%- else -%}
            <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
          {%- endif -%}

          <div style="display:flex;gap:12px;margin-bottom:24px;align-items:center;">
            <label style="font-size:0.75rem;letter-spacing:0.1em;text-transform:uppercase;color:var(--color-text-muted);">Qty</label>
            <input type="number" name="quantity" value="1" min="1"
              style="width:70px;padding:10px;background:var(--color-surface);border:1px solid var(--color-border);color:var(--color-text);text-align:center;font-family:inherit;font-size:1rem;outline:none;">
          </div>

          <button type="submit" class="btn btn--gold btn--full"
            {% unless product.available %}disabled{% endunless %}
            style="font-size:0.9rem;padding:16px;margin-bottom:12px;">
            {%- if product.available -%}Add to Cart{%- else -%}Out of Stock{%- endif -%}
          </button>
        {%- endform -%}

        {%- if product.description != blank -%}
        <div class="product-detail-desc" style="margin-top:32px;padding-top:32px;border-top:1px solid var(--color-border);">
          <h3 style="font-size:1rem;letter-spacing:0.1em;text-transform:uppercase;margin-bottom:16px;">Product Details</h3>
          {{ product.description }}
        </div>
        {%- endif -%}

        <div style="margin-top:24px;padding:16px;background:var(--color-surface);border:1px solid var(--color-border);">
          <p style="font-size:0.8rem;color:var(--color-text-muted);margin-bottom:6px;">&#10003; Free shipping on orders over ₹999</p>
          <p style="font-size:0.8rem;color:var(--color-text-muted);margin-bottom:6px;">&#10003; Gift wrapping available</p>
          <p style="font-size:0.8rem;color:var(--color-text-muted);">&#10003; Easy 7-day returns</p>
        </div>
      </div>
    </div>
  </div>
</section>
