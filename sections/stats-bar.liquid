<section class="stats-bar">
  <div class="container">
    <div class="stats-grid">
      {%- for block in section.blocks -%}
        <div class="stat-item fade-up" {{ block.shopify_attributes }}>
          <span class="stat-number">{{ block.settings.number }}</span>
          <span class="stat-label">{{ block.settings.label }}</span>
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>
{% schema %}{"name":"Stats Bar","tag":"section","max_blocks":4,"settings":[],"blocks":[{"type":"stat","name":"Stat","settings":[{"type":"text","id":"number","label":"Number","default":"500+"},{"type":"text","id":"label","label":"Label","default":"Happy Customers"}]}],"presets":[{"name":"Stats Bar"}]}{% endschema %}
