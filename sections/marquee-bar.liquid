<div class="marquee-bar">
  <div class="marquee-track">
    {%- for i in (1..4) -%}
      <span>{{ section.settings.text_1 }}</span><span class="marquee-dot">&#9670;</span>
      <span>{{ section.settings.text_2 }}</span><span class="marquee-dot">&#9670;</span>
      <span>{{ section.settings.text_3 }}</span><span class="marquee-dot">&#9670;</span>
    {%- endfor -%}
  </div>
</div>
{% schema %}{"name":"Marquee Bar","tag":"section","settings":[{"type":"text","id":"text_1","label":"Text 1","default":"Free Shipping on Orders Over ₹999"},{"type":"text","id":"text_2","label":"Text 2","default":"Gift Wrapping Available"},{"type":"text","id":"text_3","label":"Text 3","default":"Easy 7-Day Returns"}],"presets":[{"name":"Marquee Bar"}]}{% endschema %}
