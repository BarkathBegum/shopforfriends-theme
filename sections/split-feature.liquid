<section class="split-feature section">
  <div class="container">
    <div class="split-grid{% if section.settings.image_position == 'right' %} split-grid--reverse{% endif %}">
      <div class="split-image fade-up">
        {%- if section.settings.image != blank -%}
          <img src="{{ section.settings.image | image_url: width: 800 }}" alt="{{ section.settings.heading | escape }}" width="800" loading="lazy">
        {%- else -%}
          <div class="split-image-placeholder"></div>
        {%- endif -%}
      </div>
      <div class="split-content fade-up">
        <p class="section-eyebrow">{{ section.settings.eyebrow }}</p>
        <h2>{{ section.settings.heading }}</h2>
        <p>{{ section.settings.description }}</p>
        {%- if section.settings.btn_label != blank -%}
          <a href="{{ section.settings.btn_url }}" class="btn btn--gold">{{ section.settings.btn_label }}</a>
        {%- endif -%}
      </div>
    </div>
  </div>
</section>
{% schema %}{"name":"Split Feature","tag":"section","settings":[{"type":"select","id":"image_position","label":"Image position","options":[{"value":"left","label":"Left"},{"value":"right","label":"Right"}],"default":"left"},{"type":"image_picker","id":"image","label":"Image"},{"type":"text","id":"eyebrow","label":"Eyebrow","default":"Our Philosophy"},{"type":"text","id":"heading","label":"Heading","default":"Crafted with Intention"},{"type":"textarea","id":"description","label":"Description","default":"Every piece is chosen for its craftsmanship."},{"type":"text","id":"btn_label","label":"Button label","default":"Discover Our Story"},{"type":"url","id":"btn_url","label":"Button link"}],"presets":[{"name":"Split Feature"}]}{% endschema %}
