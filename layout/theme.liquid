<!DOCTYPE html>
<html lang="{{ request.locale.iso_code }}">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <meta name="theme-color" content="#0f0f0f">
  <title>
    {%- if page_title == blank -%}{{ shop.name }}{%- else -%}{{ page_title }} — {{ shop.name }}{%- endif -%}
  </title>
  {%- if page_description -%}
    <meta name="description" content="{{ page_description | escape }}">
  {%- endif -%}

  <!-- Preconnect fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;1,300;1,400&family=Jost:wght@300;400;500&display=swap" rel="stylesheet">

  <!-- Favicon -->
  {%- if settings.favicon != blank -%}
    <link rel="icon" type="image/png" href="{{ settings.favicon | image_url: width: 32 }}">
  {%- endif -%}

  {{ content_for_header }}

  {{ 'theme.css' | asset_url | stylesheet_tag }}
</head>
<body class="template-{{ template.name }}">

  <!-- Announcement Bar -->
  {%- if settings.announcement_text != blank -%}
    <div class="announcement-bar">{{ settings.announcement_text }}</div>
  {%- endif -%}

  <!-- Header -->
  {% section 'header' %}

  <!-- Mobile Nav Overlay -->
  <nav class="mobile-nav" aria-hidden="true">
    <div class="mobile-nav-inner">
      {% for link in linklists[settings.main_menu].links %}
        <a href="{{ link.url }}" class="mobile-nav-link">{{ link.title }}</a>
      {% endfor %}
    </div>
  </nav>

  <!-- Cart Drawer -->
  <div class="cart-overlay" aria-hidden="true"></div>
  <aside class="cart-drawer" aria-label="Shopping cart">
    <div class="cart-header">
      <h2 class="cart-title">Your Cart</h2>
      <button class="cart-close" data-close-cart aria-label="Close cart">&times;</button>
    </div>
    <div class="cart-items">
      {%- if cart.item_count == 0 -%}
        <p style="color:var(--color-text-muted);text-align:center;margin-top:40px;">Your cart is empty.</p>
      {%- else -%}
        {%- for item in cart.items -%}
          <div class="cart-item">
            <img class="cart-item-image" src="{{ item.image | image_url: width: 160 }}" alt="{{ item.title | escape }}">
            <div class="cart-item-details">
              <div class="cart-item-name">{{ item.product.title }}</div>
              {%- unless item.variant.title == 'Default Title' -%}
                <div class="cart-item-variant">{{ item.variant.title }}</div>
              {%- endunless -%}
              <div class="cart-item-price">{{ item.final_line_price | money }}</div>
            </div>
          </div>
        {%- endfor -%}
      {%- endif -%}
    </div>
    <div class="cart-footer">
      <div class="cart-subtotal">
        <span class="cart-subtotal-label">Subtotal</span>
        <span class="cart-subtotal-amount">{{ cart.total_price | money }}</span>
      </div>
      <a href="/checkout" class="btn btn--gold" style="width:100%;justify-content:center;">
        Proceed to Checkout
      </a>
    </div>
  </aside>

  <!-- Main Content -->
  <main id="main-content" role="main">
    {{ content_for_layout }}
  </main>

  <!-- Footer -->
  {% section 'footer' %}

  <!-- Scripts -->
  {{ 'theme.js' | asset_url | script_tag }}

</body>
</html>

<!-- Mobile Nav Styles (inline for simplicity) -->
<style>
.mobile-nav {
  position: fixed; inset: 0;
  background: var(--color-bg);
  z-index: 999;
  display: flex; flex-direction: column;
  padding: 100px 40px 40px;
  transform: translateX(-100%);
  transition: transform var(--transition);
}
.mobile-nav.open { transform: translateX(0); }
.mobile-nav-link {
  font-family: var(--font-heading);
  font-size: 2rem;
  color: var(--color-text);
  padding: 12px 0;
  border-bottom: 1px solid var(--color-border);
  display: block;
  transition: color var(--transition-fast);
}
.mobile-nav-link:hover { color: var(--color-gold); }
.hamburger.open span:nth-child(1) { transform: rotate(45deg) translate(4px, 4px); }
.hamburger.open span:nth-child(2) { opacity: 0; }
.hamburger.open span:nth-child(3) { transform: rotate(-45deg) translate(4px, -4px); }
</style>
